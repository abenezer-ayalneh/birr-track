# =============================================================================
# Birr Track — Production Environment
# Copy to .env and fill in all empty values before deploying.
# Generate secrets with: openssl rand -hex 24
# =============================================================================

# App
BACKEND_PORT=3004
MINI_APP_PORT=3003
APP_BASE_URL=https://birr-track-api.abenezer-ayalneh.dev
NODE_ENVIRONMENT=production
CORS_ALLOWED_ORIGINS=https://birr-track-telegram-app.abenezer-ayalneh.dev
FRONTEND_APP_URL=https://birr-track-telegram-app.abenezer-ayalneh.dev

# Auth
JWT_SECRET=
PLATFORM_OWNER_TELEGRAM_ID=
TELEGRAM_INITDATA_EXPIRES_SECONDS=300

# Throttle
THROTTLER_TTL=60000
THROTTLER_LIMIT=30

# Database — the backend connects over the Docker network, so DATABASE_PORT is the
# INTERNAL container port and must stay 5432 (what postgres:16-alpine listens on).
# DATABASE_EXTERNAL_PORT is the VPS-host port published for outside access (e.g. a
# tunneled DB client); bump it if 5432 is already taken on the host. The backend is
# unaffected by the external port because it never uses it.
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_EXTERNAL_PORT=5433
DATABASE_NAME=birr_track

# Redis — REDIS_PORT is the INTERNAL container port and must stay 6379.
# REDIS_EXTERNAL_PORT is the VPS-host port published for outside access.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6380

# RunPod VLM Worker
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
VLM_REQUEST_TIMEOUT_MS=120000

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=https://birr-track-api.abenezer-ayalneh.dev
# Path the auth guard treats as public so Telegram can POST without a JWT.
# Must match the webhook route base; the secret segment is matched by prefix.
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_PHOTO_RATE_LIMIT=30
TELEGRAM_PHOTO_RATE_WINDOW_SECONDS=60
TELEGRAM_FILE_DOWNLOAD_TIMEOUT_MS=30000

# Object Storage — MinIO (Docker service name as host)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=birr-track-receipts
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=true
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# Admin Panel (Vite build-time vars)
VITE_API_BASE_URL=https://birr-track-api.abenezer-ayalneh.dev
VITE_BOT_USERNAME=
