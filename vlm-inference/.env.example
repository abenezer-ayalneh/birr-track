# Inference service (port 8000)
HOST=0.0.0.0
PORT=8000

# Backend: ollama (default) or peft (fine-tuned LoRA adapter)
VLM_BACKEND=ollama

# --- Ollama (VLM_BACKEND=ollama) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:latest
# VLM_EXTRACT_PROMPT=   # optional; default prompts/receipt_extract.txt

# --- PEFT (VLM_BACKEND=peft) ---
# pip install -r requirements-peft.txt
# Unzip Kaggle adapter zip to adapters/qwen25vl-3b-birrtrack-lora/
HF_BASE_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
LORA_ADAPTER_PATH=./adapters/qwen25vl-3b-birrtrack-lora
# HF_DEVICE=cuda:0   # optional; auto-detects cuda / mps / cpu
# VLM_PEFT_PROMPT=   # optional; default prompts/receipt_extract_training.txt

# Timeout for a single extraction request (ms). PEFT cold start can be slow.
VLM_REQUEST_TIMEOUT_MS=120000
