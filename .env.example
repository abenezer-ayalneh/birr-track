#App
BACKEND_PORT=3004
MINI_APP_PORT=3003
APP_BASE_URL="http://localhost:${BACKEND_PORT}"
NODE_ENVIRONMENT=development
CORS_ALLOWED_ORIGINS='http://localhost:4200,http://localhost:4371'
FRONTEND_APP_URL=http://localhost:4200

#Auth
JWT_SECRET=
PLATFORM_OWNER_TELEGRAM_ID=
TELEGRAM_INITDATA_EXPIRES_SECONDS=300

#Throttle
THROTTLER_TTL=60000
THROTTLER_LIMIT=10

#Database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=birr_track

#Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RunPod VLM Worker
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
VLM_REQUEST_TIMEOUT_MS=120000

#Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=
# Path the auth guard treats as public so Telegram can POST without a JWT (see optional-jwt-auth.guard.ts)
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Required HTTPS destination for the bot's Contact Support action (for example, https://t.me/birr_track_support)
TELEGRAM_SUPPORT_URL=https://t.me/HappySquared
TELEGRAM_PHOTO_RATE_LIMIT=30
TELEGRAM_PHOTO_RATE_WINDOW_SECONDS=60
TELEGRAM_FILE_DOWNLOAD_TIMEOUT_MS=30000

#Object Storage (S3-compatible; MinIO for local dev)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=birr-track-receipts
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=true
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

#Testing
SMOKE_APP_BASE_URL=
SMOKE_WAIT_FOR_BACKEND_MS=120000
SMOKE_TELEGRAM_FILE_ID=
SMOKE_TIMEOUT_MS=120000
