#App
PORT=3000
APP_BASE_URL="http://localhost:${PORT}"
NODE_ENVIRONMENT=development
NODE_VERSION=20.11.0
CORS_ALLOWED_ORIGINS='http://localhost:4200,http://localhost:4371'
FRONTEND_APP_URL=http://localhost:4200

#Throttle
THROTTLER_TTL=60000
THROTTLER_LIMIT=10

#Database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=birr_track
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public"

#Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# VLM (Ollama or fine-tuned PEFT via ../vlm-inference on port 8000)
# Run order: vlm-inference -> this backend
# Ollama path: ollama serve + VLM_BACKEND=ollama (default)
# PEFT path: unzip adapter to vlm-inference/adapters/, VLM_BACKEND=peft, pip install -r requirements-peft.txt
# POST /extract returns { bankName, amount, transactionId, timestamp, currency, confidence }
# See ../vlm-inference/README.md and ../qwen-vlm-training/README.md
VLM_SERVICE_URL=http://localhost:8000
# Match vlm-inference timeout; PEFT inference can exceed 30s on first request
VLM_REQUEST_TIMEOUT_MS=120000

#Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

#Testing
SMOKE_APP_BASE_URL=
SMOKE_WAIT_FOR_BACKEND_MS=120000
SMOKE_TELEGRAM_FILE_ID=
SMOKE_TIMEOUT_MS=120000
